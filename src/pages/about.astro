---
import BaseLayout from "../layouts/BaseLayout.astro";
import about from "../content/site/about.json";
---
<BaseLayout
  title={about.seo.title}
  description={about.seo.description}
>
  <!-- HERO -->
  <section class="mx-auto max-w-content px-5 sm:px-8 pt-16 md:pt-24 pb-12 md:pb-20">
    <div class="grid gap-10 md:grid-cols-2 md:gap-16 items-center">
      <div class="md:order-2 fade-up">
        <img
          src="/images/tom-about.jpg"
          alt={about.hero.imageAlt}
          class="w-full h-auto aspect-[4/5] object-cover"
          loading="eager"
          decoding="async"
        />
      </div>

      <div class="md:order-1 text-right fade-up">
        <p class="eyebrow-label text-teal-deep mb-4">{about.hero.eyebrow}</p>
        <h1 class="section-h2 mb-6">{about.hero.headlineLine1}<br />{about.hero.headlineLine2}</h1>
        <p class="font-serif text-[22px] md:text-[26px] leading-[1.4] text-ink-soft">
          {about.hero.lead}
        </p>
      </div>
    </div>
  </section>

  <!-- LONG READ -->
  <section class="mx-auto max-w-prose px-5 sm:px-8 py-16 md:py-24 text-right prose-body">
    {
      about.sections.map((section, i) => (
        <div class={`fade-up ${i > 0 ? "mt-12" : ""}`}>
          <h2 class={`section-h3 font-bold mb-4 ${i === 0 ? "mt-0" : ""}`}>{section.heading}</h2>
          {section.paragraphs.map((p, j) => (
            <p class={`body-prose text-ink-soft leading-[1.8] ${j < section.paragraphs.length - 1 ? "mb-5" : ""}`}>
              {p}
            </p>
          ))}
        </div>
      ))
    }

    <div class="fade-up mt-16 text-center">
      <a href={about.cta.href} class="btn btn-ghost-ink">
        <span>{about.cta.text}</span>
        <span aria-hidden="true">←</span>
      </a>
    </div>
  </section>
</BaseLayout>
