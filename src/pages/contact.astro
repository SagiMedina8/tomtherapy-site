---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site, whatsappLink } from "../data/site";
import contact from "../content/site/contact.json";
---
<BaseLayout
  title={contact.seo.title}
  description={contact.seo.description}
>
  <section class="mx-auto max-w-content px-5 sm:px-8 pt-20 md:pt-28 pb-16 md:pb-24">
    <div class="grid gap-12 md:grid-cols-2 md:gap-16">
      <!-- Right col: contact details -->
      <div class="md:order-2 text-right space-y-8 fade-up">
        <div>
          <p class="eyebrow-label text-teal-deep mb-4">{contact.header.eyebrow}</p>
          <h1 class="section-h2 mb-6">{contact.header.title}</h1>
          <p class="body-prose text-ink-soft leading-[1.75] max-w-prose">
            {contact.header.lead}
          </p>
        </div>

        <!-- Primary: WhatsApp -->
        <div class="border border-hairline bg-paper p-6 md:p-8">
          <p class="eyebrow-label text-teal-deep mb-3">{contact.whatsapp.eyebrow}</p>
          <h2 class="section-h3 font-bold mb-3">{contact.whatsapp.title}</h2>
          <p class="text-sm text-ink-soft mb-5 leading-relaxed">
            {contact.whatsapp.body}
          </p>
          <a
            href={whatsappLink()}
            target="_blank"
            rel="noopener"
            class="btn btn-primary w-full sm:w-auto"
          >
            <span dir="ltr" class="tabular-nums">{site.whatsappDisplay}</span>
            <span aria-hidden="true">←</span>
          </a>
        </div>

        <!-- Email -->
        <div>
          <p class="eyebrow-label text-teal-deep mb-2">{contact.labels.emailEyebrow}</p>
          <a
            href={`mailto:${site.email}`}
            class="font-serif text-[20px] text-ink hover:text-teal-deep transition-colors break-all"
          >
            {site.email}
          </a>
        </div>

        <!-- Hours -->
        <div>
          <p class="eyebrow-label text-teal-deep mb-4">{contact.labels.hoursEyebrow}</p>
          <ul class="space-y-1.5 text-sm">
            {
              site.hours.map((h) => (
                <li class="flex items-center justify-between gap-4">
                  <span class="text-ink">
                    {h.day}
                    {h.label && (
                      <span class="text-ink-soft/70 text-xs"> · {h.label}</span>
                    )}
                  </span>
                  <span dir="ltr" class="text-ink-soft tabular-nums">
                    {h.hours}
                  </span>
                </li>
              ))
            }
          </ul>
        </div>

        <!-- Addresses -->
        <div class="grid sm:grid-cols-2 gap-6 pt-4 border-t border-hairline">
          {
            site.addresses.map((a) => (
              <div>
                <p class="eyebrow-label text-teal-deep mb-2">{a.title}</p>
                <p class="text-sm text-ink">
                  {a.street}, {a.city}
                  {a.note && (
                    <span class="block text-ink-soft/60 text-xs mt-1">
                      {a.note}
                    </span>
                  )}
                </p>
              </div>
            ))
          }
        </div>
      </div>

      <!-- Left col: form + map -->
      <div class="md:order-1 fade-up">
        <form
          name="contact"
          method="POST"
          data-netlify="true"
          netlify-honeypot="bot-field"
          class="bg-paper border border-hairline p-6 md:p-8 space-y-5"
        >
          <input type="hidden" name="form-name" value="contact" />
          <p class="hidden">
            <label>אל תמלא:<input name="bot-field" /></label>
          </p>

          <p class="eyebrow-label text-teal-deep">{contact.form.eyebrow}</p>
          <h2 class="section-h3 font-bold mb-2 -mt-2">{contact.form.title}</h2>

          <div>
            <label for="name" class="block text-sm font-semibold text-ink mb-1.5">
              {contact.form.labelName}
            </label>
            <input
              type="text"
              id="name"
              name="name"
              required
              autocomplete="name"
              class="w-full h-12 px-4 bg-cream border border-hairline focus:border-teal focus:outline-none transition-colors text-ink text-right"
            />
          </div>

          <div>
            <label for="phone" class="block text-sm font-semibold text-ink mb-1.5">
              {contact.form.labelPhone}
            </label>
            <input
              type="tel"
              id="phone"
              name="phone"
              required
              dir="ltr"
              autocomplete="tel"
              class="w-full h-12 px-4 bg-cream border border-hairline focus:border-teal focus:outline-none transition-colors text-ink text-left"
            />
          </div>

          <div>
            <label for="email" class="block text-sm font-semibold text-ink mb-1.5">
              {contact.form.labelEmail} <span class="text-ink-soft/60 text-xs font-normal">{contact.form.labelEmailOptional}</span>
            </label>
            <input
              type="email"
              id="email"
              name="email"
              dir="ltr"
              autocomplete="email"
              class="w-full h-12 px-4 bg-cream border border-hairline focus:border-teal focus:outline-none transition-colors text-ink text-left"
            />
          </div>

          <div>
            <label for="message" class="block text-sm font-semibold text-ink mb-1.5">
              {contact.form.labelMessage}
            </label>
            <textarea
              id="message"
              name="message"
              required
              rows="5"
              class="w-full px-4 py-3 bg-cream border border-hairline focus:border-teal focus:outline-none transition-colors text-ink text-right leading-relaxed"
            ></textarea>
          </div>

          <button type="submit" class="btn btn-primary w-full">
            {contact.form.submit}
          </button>

          <p class="text-xs text-ink-soft/70 pt-2">
            {contact.form.disclaimer}
          </p>
        </form>

        <!-- Google Maps — two locations -->
        <div class="mt-10">
          <p class="eyebrow-label text-teal-deep mb-4 text-right">{contact.labels.locationEyebrow}</p>

          <div class="space-y-6">
            <!-- Ramat Gan -->
            <div>
              <p class="text-xs text-ink-soft/80 mb-2 text-right font-semibold">
                הקליניקה הראשית · ארניה 6, רמת גן
              </p>
              <div class="relative w-full overflow-hidden border border-hairline bg-paper" style="height: 260px;">
                <iframe
                  src="https://www.google.com/maps?q=%D7%90%D7%A8%D7%A0%D7%99%D7%94%206,%20%D7%A8%D7%9E%D7%AA%20%D7%92%D7%9F&output=embed"
                  title="מפת מיקום — ארניה 6, רמת גן"
                  loading="lazy"
                  referrerpolicy="no-referrer-when-downgrade"
                  class="absolute inset-0 w-full h-full border-0"
                ></iframe>
              </div>
            </div>

            <!-- Tel Aviv -->
            <div>
              <p class="text-xs text-ink-soft/80 mb-2 text-right font-semibold">
                סטודיו תל אביב · Nana Home, בורוכוב 1
              </p>
              <div class="relative w-full overflow-hidden border border-hairline bg-paper" style="height: 260px;">
                <iframe
                  src="https://www.google.com/maps?q=%D7%91%D7%95%D7%A8%D7%95%D7%9B%D7%95%D7%91%201,%20%D7%AA%D7%9C%20%D7%90%D7%91%D7%99%D7%91%20%D7%99%D7%A4%D7%95&output=embed"
                  title="מפת מיקום — בורוכוב 1, תל אביב יפו"
                  loading="lazy"
                  referrerpolicy="no-referrer-when-downgrade"
                  class="absolute inset-0 w-full h-full border-0"
                ></iframe>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
