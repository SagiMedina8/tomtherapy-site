---
import BaseLayout from "../layouts/BaseLayout.astro";
import { whatsappLink } from "../data/site";
import { services } from "../data/services";
import home from "../content/site/home.json";
import BodyMap from "../components/BodyMap.astro";
---
<BaseLayout
  title={home.seo.title}
  description={home.seo.description}
  transparentOverHero={true}
  preloadHero="/images/tom-hero.jpg"
>
  <!-- HERO -->
  <section class="relative min-h-[100svh] w-full overflow-hidden bg-ink">
    <img
      src="/images/tom-hero.jpg"
      alt=""
      role="presentation"
      class="absolute inset-0 h-full w-full object-cover object-center ken-burns"
      fetchpriority="high"
      decoding="async"
    />

    <!-- Mobile: vertical gradient (text is full-width at bottom).
         Desktop: horizontal-ish gradient darkening the right (RTL text) side. -->
    <div
      class="absolute inset-0 md:hidden"
      style="background: linear-gradient(to top, rgba(0,0,0,0.8) 0%, rgba(0,0,0,0.35) 40%, rgba(0,0,0,0.15) 100%);"
    ></div>
    <div
      class="absolute inset-0 hidden md:block"
      style="background: linear-gradient(to left, rgba(15,20,25,0.55) 0%, rgba(15,20,25,0.25) 35%, rgba(15,20,25,0) 55%);"
    ></div>

    <div class="relative z-10 flex min-h-[100svh] flex-col justify-end pb-[14vh] pt-28 md:pt-0">
      <div class="mx-auto w-full max-w-content px-5 sm:px-8">
        <div class="md:ms-auto md:max-w-[560px] text-white text-right">
          <p class="eyebrow-label text-teal/95 mb-5 md:mb-6">
            {home.hero.eyebrow}
          </p>
          <h1 class="hero-headline">
            {home.hero.headlineLine1}<br />{home.hero.headlineLine2}
          </h1>
          <p class="mt-6 body-prose max-w-[520px] ms-auto text-white/90 leading-[1.65]">
            {home.hero.subheadLine1}<br />
            {home.hero.subheadLine2}
          </p>

          <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:justify-end sm:gap-4">
            <a href="/booking" class="btn btn-primary">
              {home.hero.ctaPrimaryText}
              <span aria-hidden="true" class="text-lg">←</span>
            </a>
            <a
              href={whatsappLink()}
              target="_blank"
              rel="noopener"
              class="btn btn-ghost"
            >
              {home.hero.ctaSecondaryText}
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- INTERACTIVE BODY MAP -->
  <BodyMap />

  <!-- POST-HERO STATEMENT SECTION -->
  <section class="bg-cream">
    <div class="mx-auto max-w-[720px] px-5 sm:px-8 py-32 md:py-40">
      <div class="fade-up">
        <p class="eyebrow-label text-teal-deep mb-8 text-center">{home.story.eyebrow}</p>
        <h2 class="section-h2 text-center mb-10">
          {home.story.headlineLine1}<br class="hidden sm:block" />
          <span> {home.story.headlineLine2}</span>
        </h2>

        <div class="body-prose text-ink-soft space-y-6 leading-[1.8]">
          <p>{home.story.paragraph1}</p>
          <p>{home.story.paragraph2}</p>
        </div>

        <div class="mt-10 text-center">
          <a
            href={home.story.ctaLink}
            class="inline-flex items-center gap-2 text-ink hover:text-teal-deep transition-colors border-b border-teal pb-1"
          >
            <span>{home.story.ctaText}</span>
            <span aria-hidden="true">←</span>
          </a>
        </div>
      </div>
    </div>

    <!-- Sub-hint to explore services -->
    <div class="mx-auto max-w-content px-5 sm:px-8 pb-24">
      <hr class="hairline mb-10" />
      <ul class="flex flex-wrap items-center justify-center gap-x-8 gap-y-3 text-sm display-serif uppercase tracking-[0.2em] text-ink-soft">
        {
          services.map((s) => (
            <li>
              <a
                href={`/services#${s.slug}`}
                class="hover:text-teal-deep transition-colors"
              >
                {s.titleEn}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>
</BaseLayout>
