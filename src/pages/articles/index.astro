---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/PageHeader.astro";
import ArticleCard from "../../components/ArticleCard.astro";
import { getCollection } from "astro:content";
import articleIndex from "../../content/site/articleIndex.json";

const articles = (await getCollection("articles")).sort(
  (a, b) =>
    new Date(b.data.publishedAt).getTime() -
    new Date(a.data.publishedAt).getTime(),
);
---
<BaseLayout
  title={articleIndex.seo.title}
  description={articleIndex.seo.description}
>
  <PageHeader
    eyebrow={articleIndex.header.eyebrow}
    title={articleIndex.header.title}
    lead={articleIndex.header.lead}
  />

  <section class="mx-auto max-w-content px-5 sm:px-8 pb-24">
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3 md:gap-8">
      {articles.map((article) => <ArticleCard article={article} />)}
    </div>
  </section>
</BaseLayout>
