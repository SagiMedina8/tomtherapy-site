---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import ProcessStep from "../components/ProcessStep.astro";
import { processSteps } from "../data/process-steps";
import processPage from "../content/site/process.json";
---
<BaseLayout
  title={processPage.seo.title}
  description={processPage.seo.description}
>
  <PageHeader
    eyebrow={processPage.header.eyebrow}
    title={processPage.header.title}
    lead={processPage.header.lead}
  />

  <section class="mx-auto max-w-[920px] px-5 sm:px-8 pb-20">
    {processSteps.map((step) => <ProcessStep step={step} />)}
  </section>

  <section class="mx-auto max-w-prose px-5 sm:px-8 pb-24 text-center">
    <a href={processPage.cta.href} class="btn btn-ghost-ink">
      <span>{processPage.cta.text}</span>
      <span aria-hidden="true">←</span>
    </a>
  </section>
</BaseLayout>
