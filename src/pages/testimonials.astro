---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import TestimonialCard from "../components/TestimonialCard.astro";
import { testimonials } from "../data/testimonials";
---
<BaseLayout
  title="המלצות"
  description="מטופלים מספרים — רצים, ספורטאים, אנשי משרד. הם הגיעו עם כאב שלא עבר, ויצאו עם כלים."
>
  <PageHeader
    eyebrow="המלצות"
    title="מה אומרים אחרי שהטיפול עבד"
    lead="אוסף של עדויות ממטופלים שעברו תהליך. כל אחד והסיפור שלו — אבל המכנה המשותף תמיד אותו דבר: הכאב לא חזר."
  />

  <section class="mx-auto max-w-content px-5 sm:px-8 pb-24">
    <div class="grid gap-6 md:grid-cols-2 md:gap-8">
      {testimonials.map((t) => <TestimonialCard testimonial={t} />)}
    </div>
  </section>

  <section class="mx-auto max-w-prose px-5 sm:px-8 pb-24 text-center">
    <a href="/booking" class="btn btn-ghost-ink">
      <span>להתחיל את התהליך</span>
      <span aria-hidden="true">←</span>
    </a>
  </section>
</BaseLayout>
