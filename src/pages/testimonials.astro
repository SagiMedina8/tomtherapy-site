---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import TestimonialCard from "../components/TestimonialCard.astro";
import { testimonials } from "../data/testimonials";
import testimonialsPage from "../content/site/testimonials.json";
---
<BaseLayout
  title={testimonialsPage.seo.title}
  description={testimonialsPage.seo.description}
>
  <PageHeader
    eyebrow={testimonialsPage.header.eyebrow}
    title={testimonialsPage.header.title}
    lead={testimonialsPage.header.lead}
  />

  <section class="mx-auto max-w-content px-5 sm:px-8 pb-24">
    <div class="grid gap-6 md:grid-cols-2 md:gap-8">
      {testimonials.map((t) => <TestimonialCard testimonial={t} />)}
    </div>
  </section>

  <section class="mx-auto max-w-prose px-5 sm:px-8 pb-24 text-center">
    <a href={testimonialsPage.cta.href} class="btn btn-ghost-ink">
      <span>{testimonialsPage.cta.text}</span>
      <span aria-hidden="true">←</span>
    </a>
  </section>
</BaseLayout>
