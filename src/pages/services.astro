---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import ServiceCard from "../components/ServiceCard.astro";
import { services } from "../data/services";
import { whatsappLink } from "../data/site";

const variants = [1, 2, 3, 4] as const;
---
<BaseLayout
  title="שירותים"
  description="ארבעה כלים, שילוב אחד: דיקור יבש, עיסוי רפואי, שיקום ספורט ותרגול מותאם אישית. כל טיפול נבנה סביב המטופל — לא סביב הטכניקה."
>
  <PageHeader
    eyebrow="שירותים"
    title="ארבעה כלים. שילוב אחד."
    lead="הבחירה בכלי הנכון תלויה במה שהגוף שלך צריך באותו רגע — לא בטכניקה שהמטפל הכי אוהב. כל טיפול משלב בין השיטות האלה במינונים שונים."
  />

  <section class="mx-auto max-w-content px-5 sm:px-8 pb-24">
    <div class="grid gap-6 md:grid-cols-2 md:gap-8 items-stretch">
      {
        services.map((s, i) => (
          <ServiceCard service={s} variant={variants[i]} index={i} />
        ))
      }
    </div>
  </section>

  <!-- CTA bar -->
  <section class="bg-ink text-cream py-20">
    <div class="mx-auto max-w-content px-5 sm:px-8 text-center">
      <p class="eyebrow-label text-teal mb-5">השלב הבא</p>
      <h2 class="section-h2 mb-6">לא בטוח איזה טיפול מתאים לך?</h2>
      <p class="body-prose text-cream/80 max-w-prose mx-auto mb-8">
        האבחון הראשוני הוא מפגש של שאלות — לא של החלטות. נבין קודם מה קורה, ורק אחר כך נבחר בכלים.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/booking" class="btn btn-primary">
          <span>קבע אבחון</span>
          <span aria-hidden="true">←</span>
        </a>
        <a
          href={whatsappLink()}
          target="_blank"
          rel="noopener"
          class="btn btn-ghost"
        >
          שאלה קצרה בוואטסאפ
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
