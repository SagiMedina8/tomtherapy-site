---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import ServiceCard from "../components/ServiceCard.astro";
import { services } from "../data/services";
import { whatsappLink } from "../data/site";
import servicesPage from "../content/site/services.json";

const variants = [1, 2, 3, 4] as const;
---
<BaseLayout
  title={servicesPage.seo.title}
  description={servicesPage.seo.description}
>
  <PageHeader
    eyebrow={servicesPage.header.eyebrow}
    title={servicesPage.header.title}
    lead={servicesPage.header.lead}
  />

  <section class="mx-auto max-w-content px-5 sm:px-8 pb-24">
    <div class="grid gap-6 md:grid-cols-2 md:gap-8 items-stretch">
      {
        services.map((s, i) => (
          <ServiceCard service={s} variant={variants[i]} index={i} />
        ))
      }
    </div>
  </section>

  <!-- CTA bar -->
  <section class="bg-ink text-cream py-20">
    <div class="mx-auto max-w-content px-5 sm:px-8 text-center">
      <p class="eyebrow-label text-teal mb-5">{servicesPage.ctaBar.eyebrow}</p>
      <h2 class="section-h2 mb-6">{servicesPage.ctaBar.headline}</h2>
      <p class="body-prose text-cream/80 max-w-prose mx-auto mb-8">
        {servicesPage.ctaBar.body}
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/booking" class="btn btn-primary">
          <span>{servicesPage.ctaBar.ctaPrimaryText}</span>
          <span aria-hidden="true">←</span>
        </a>
        <a
          href={whatsappLink()}
          target="_blank"
          rel="noopener"
          class="btn btn-ghost"
        >
          {servicesPage.ctaBar.ctaSecondaryText}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
