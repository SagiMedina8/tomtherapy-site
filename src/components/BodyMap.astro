---
import bodyMap from "../content/site/bodyMap.json";
import type { BodyMapContent, BodyMapRegion } from "../types/content";

const data = bodyMap as BodyMapContent;
const regions = data.regions as BodyMapRegion[];

// Hotspot coordinates + label placement in a viewBox -60 -5 320 515
// (body coords remain 0 0 200 500; extra padding reserves room for labels)
type Anchor = "start" | "middle" | "end";
type Hotspot = { cx: number; cy: number; lx: number; ly: number; anchor: Anchor };

const hotspots: Record<string, Hotspot> = {
  neck:         { cx: 100, cy: 75,  lx: 80,  ly: 78,  anchor: "end"   },
  shoulder:     { cx: 135, cy: 110, lx: 157, ly: 113, anchor: "start" },
  scapula:      { cx: 65,  cy: 115, lx: 43,  ly: 118, anchor: "end"   },
  "upper-back": { cx: 100, cy: 140, lx: 122, ly: 143, anchor: "start" },
  elbow:        { cx: 155, cy: 200, lx: 177, ly: 203, anchor: "start" },
  wrist:        { cx: 170, cy: 270, lx: 192, ly: 273, anchor: "start" },
  "lower-back": { cx: 100, cy: 235, lx: 78,  ly: 238, anchor: "end"   },
  hip:          { cx: 125, cy: 260, lx: 150, ly: 252, anchor: "start" },
  groin:        { cx: 100, cy: 290, lx: 76,  ly: 305, anchor: "end"   },
  hamstring:    { cx: 72,  cy: 325, lx: 50,  ly: 335, anchor: "end"   },
  knee:         { cx: 115, cy: 360, lx: 140, ly: 362, anchor: "start" },
  shin:         { cx: 110, cy: 400, lx: 134, ly: 402, anchor: "start" },
  calf:         { cx: 88,  cy: 415, lx: 64,  ly: 418, anchor: "end"   },
  foot:         { cx: 115, cy: 478, lx: 140, ly: 490, anchor: "start" },
};
---
<section
  id="body-map"
  class="bg-cream border-t border-hairline"
  aria-labelledby="body-map-heading"
>
  <div class="mx-auto max-w-content px-5 sm:px-8 py-20 md:py-32">
    <!-- Intro -->
    <div class="max-w-[720px] mx-auto text-center fade-up mb-12 md:mb-20">
      <p class="eyebrow-label text-teal-deep mb-4">{data.intro.eyebrow}</p>
      <h2 id="body-map-heading" class="section-h2 mb-6">{data.intro.headline}</h2>
      <p class="body-prose text-ink-soft leading-[1.75]">{data.intro.subhead}</p>
    </div>

    <!-- Map + panel grid -->
    <div class="grid gap-10 md:gap-12 md:grid-cols-[minmax(200px,320px)_1fr] items-start fade-up">
      <!-- Body SVG -->
      <div class="flex flex-col items-center md:sticky md:top-28">
        <!-- Active region indicator (visible on all screens, crucial for mobile) -->
        <div class="mb-3 md:mb-4 text-center min-h-[36px] flex items-center justify-center">
          <span
            id="body-map-active-label"
            class="font-serif text-[22px] md:text-[24px] leading-tight text-ink-soft/60 transition-opacity duration-200"
            data-default-text="בחר אזור בגוף"
          >
            בחר אזור בגוף
          </span>
        </div>
        <svg
          viewBox="-60 -10 320 520"
          class="w-full max-w-[220px] md:max-w-[280px] h-auto"
          role="img"
          aria-label="בחר אזור בגוף"
          xmlns="http://www.w3.org/2000/svg"
        >
          <!-- Body outline, minimal line-art -->
          <g fill="none" stroke="var(--ink)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <!-- Head -->
            <circle cx="100" cy="36" r="22" />
            <!-- Neck -->
            <path d="M88 55 L85 72 M112 55 L115 72" />
            <!-- Shoulders + torso outline -->
            <path d="M50 82 C 65 76, 80 74, 85 72 L 115 72 C 120 74, 135 76, 150 82" />
            <!-- Arms (outer edge) -->
            <path d="M50 82 L 40 150 L 45 230 L 55 290" />
            <path d="M150 82 L 160 150 L 155 230 L 145 290" />
            <!-- Arms (inner edge near torso) -->
            <path d="M68 95 L 62 160 L 65 230 L 70 285" />
            <path d="M132 95 L 138 160 L 135 230 L 130 285" />
            <!-- Hands (simplified) -->
            <path d="M55 290 C 50 300, 52 308, 60 308 L 68 305 L 70 285" />
            <path d="M145 290 C 150 300, 148 308, 140 308 L 132 305 L 130 285" />
            <!-- Torso sides down to hips -->
            <path d="M68 95 C 70 140, 66 200, 60 260 L 55 290" />
            <path d="M132 95 C 130 140, 134 200, 140 260 L 145 290" />
            <!-- Hip curve + pelvis -->
            <path d="M60 260 C 70 272, 90 278, 100 278 C 110 278, 130 272, 140 260" />
            <!-- Groin split -->
            <path d="M100 278 L 100 300" />
            <!-- Legs -->
            <path d="M60 260 C 62 320, 72 400, 85 475" />
            <path d="M140 260 C 138 320, 128 400, 115 475" />
            <path d="M100 300 C 95 360, 92 420, 88 475" />
            <path d="M100 300 C 105 360, 108 420, 112 475" />
            <!-- Feet -->
            <path d="M82 478 C 75 484, 72 492, 80 493 L 95 490 L 88 478" />
            <path d="M118 478 C 125 484, 128 492, 120 493 L 105 490 L 112 478" />
          </g>

          <!-- Hotspots -->
          <g id="body-map-hotspots">
            {
              regions.map((r) => {
                const h = hotspots[r.id] || {
                  cx: 100, cy: 250, lx: 120, ly: 253, anchor: "start" as Anchor,
                };
                return (
                  <g class="body-hotspot" data-region-id={r.id} data-region-label={r.label}>
                    <!-- Generous transparent touch target -->
                    <circle
                      class="body-hotspot-touch"
                      cx={h.cx}
                      cy={h.cy}
                      r="28"
                      fill="transparent"
                    />
                    <circle
                      class="body-hotspot-ring"
                      cx={h.cx}
                      cy={h.cy}
                      r="20"
                      fill="none"
                      stroke="var(--teal)"
                      stroke-width="1.5"
                      opacity="0"
                    />
                    <circle
                      class="body-hotspot-dot"
                      cx={h.cx}
                      cy={h.cy}
                      r="10"
                      fill="var(--teal)"
                      stroke="var(--cream)"
                      stroke-width="2"
                      opacity="0.85"
                    />
                    <text
                      class="body-hotspot-label"
                      x={h.lx}
                      y={h.ly}
                      text-anchor={h.anchor}
                      dominant-baseline="middle"
                    >{r.label}</text>
                    <title>{r.label}</title>
                  </g>
                );
              })
            }
          </g>
        </svg>
      </div>

      <!-- Content panel -->
      <div id="body-map-panel" class="min-h-[320px]">
        <!-- Empty / default state -->
        <div
          id="body-map-empty"
          class="card-base card-static text-center"
        >
          <p class="eyebrow-label text-teal-deep mb-4">איפה כואב?</p>
          <p class="body-prose text-ink-soft leading-[1.75]">
            בחר אזור בגוף מצד ימין כדי לקרוא על הבעיות הנפוצות באזור ועל הגישה הטיפולית.
          </p>
        </div>

        <!-- Region content templates (hidden; JS populates by reading JSON inline) -->
        <article
          id="body-map-content"
          class="card-base card-static hidden"
          aria-live="polite"
        >
          <p class="eyebrow-label text-teal-deep mb-3" data-field="label"></p>
          <h3
            id="body-map-title"
            class="section-h3 font-bold mb-4"
            tabindex="-1"
            data-field="title"
          ></h3>
          <p class="body-prose text-ink-soft leading-[1.75] mb-6" data-field="intro"></p>

          <p class="eyebrow-label text-teal-deep mb-3">בעיות נפוצות</p>
          <ul class="space-y-4 mb-8" data-field="commonProblems"></ul>

          <p class="eyebrow-label text-teal-deep mb-3">הגישה הטיפולית</p>
          <p class="body-prose text-ink-soft leading-[1.75] mb-8" data-field="approach"></p>

          <a href="/booking" class="btn btn-ghost-ink w-full sm:w-auto">
            <span>קבע פגישת אבחון</span>
            <span aria-hidden="true">←</span>
          </a>
        </article>
      </div>
    </div>

    <p class="text-xs text-ink-soft/70 text-center mt-10 max-w-prose mx-auto">
      {data.intro.disclaimer}
    </p>
  </div>

  <!-- Data inline for client-side lookup -->
  <script
    type="application/json"
    id="body-map-data"
    set:html={JSON.stringify(data.regions)}
  />

  <style>
    .body-hotspot {
      cursor: pointer;
      transition: transform 200ms cubic-bezier(0.22, 1, 0.36, 1);
    }
    .body-hotspot-dot {
      transition:
        r 200ms cubic-bezier(0.22, 1, 0.36, 1),
        opacity 200ms ease;
    }
    .body-hotspot-ring {
      transition: opacity 200ms ease;
    }
    .body-hotspot-label {
      font-family: 'Heebo', system-ui, sans-serif;
      font-size: 11px;
      font-weight: 500;
      fill: var(--ink-soft);
      pointer-events: none;
      /* Cream halo for legibility against body lines and cream bg */
      stroke: var(--cream);
      stroke-width: 3px;
      paint-order: stroke fill;
      transition:
        fill 200ms ease,
        font-weight 200ms ease;
    }
    .body-hotspot-touch {
      cursor: pointer;
    }
    .body-hotspot:hover .body-hotspot-dot,
    .body-hotspot:focus-visible .body-hotspot-dot,
    .body-hotspot.is-active .body-hotspot-dot {
      r: 13;
      opacity: 1;
    }
    .body-hotspot.is-active .body-hotspot-ring {
      opacity: 0.9;
    }
    .body-hotspot:hover .body-hotspot-label,
    .body-hotspot:focus-visible .body-hotspot-label,
    .body-hotspot.is-active .body-hotspot-label {
      fill: var(--teal-deep);
      font-weight: 700;
    }
    .body-hotspot:focus-visible {
      outline: none;
    }
    .body-hotspot:focus-visible .body-hotspot-ring {
      opacity: 1;
    }
    /* Smaller labels on mobile — still readable with halo */
    @media (max-width: 767px) {
      .body-hotspot-label {
        font-size: 9.5px;
        stroke-width: 2.5px;
      }
    }
    #body-map-active-label.is-active {
      color: var(--teal-deep);
      opacity: 1;
    }
    /* Fade transition for panel content swap */
    #body-map-content {
      transition: opacity 200ms ease;
    }
    #body-map-content.is-swapping {
      opacity: 0;
    }
    @media (prefers-reduced-motion: reduce) {
      #body-map-content,
      .body-hotspot,
      .body-hotspot-dot,
      .body-hotspot-ring,
      .body-hotspot-label {
        transition: none !important;
      }
    }
  </style>

  <script>
    type Region = {
      id: string;
      label: string;
      title: string;
      intro: string;
      commonProblems: Array<{ name: string; description: string }>;
      approach: string;
    };

    const dataEl = document.getElementById("body-map-data");
    if (dataEl) {
      const regions: Region[] = JSON.parse(dataEl.textContent || "[]");
      const byId = new Map(regions.map((r) => [r.id, r]));

      const emptyState = document.getElementById("body-map-empty");
      const contentEl = document.getElementById("body-map-content");
      const titleEl = document.getElementById("body-map-title");
      const activeLabelEl = document.getElementById("body-map-active-label");

      const hotspots = Array.from(
        document.querySelectorAll<SVGGElement>(".body-hotspot"),
      );

      // Make hotspots focusable
      for (const h of hotspots) {
        h.setAttribute("tabindex", "0");
        h.setAttribute("role", "button");
        const id = h.dataset.regionId;
        const region = id ? byId.get(id) : undefined;
        if (region) {
          h.setAttribute("aria-label", region.label);
        }
      }

      function selectRegion(id: string) {
        const region = byId.get(id);
        if (!region || !contentEl || !emptyState || !titleEl) return;

        // Active hotspot highlight
        for (const h of hotspots) {
          h.classList.toggle("is-active", h.dataset.regionId === id);
        }

        // Update the active region name above the SVG
        if (activeLabelEl) {
          activeLabelEl.textContent = region.label;
          activeLabelEl.classList.add("is-active");
        }

        // Fade-swap content
        contentEl.classList.add("is-swapping");
        window.setTimeout(() => {
          // Populate fields
          const setField = (name: string, value: string) => {
            const el = contentEl.querySelector<HTMLElement>(
              `[data-field="${name}"]`,
            );
            if (el) el.textContent = value;
          };
          setField("label", region.label);
          setField("title", region.title);
          setField("intro", region.intro);
          setField("approach", region.approach);

          const list = contentEl.querySelector<HTMLUListElement>(
            '[data-field="commonProblems"]',
          );
          if (list) {
            list.innerHTML = "";
            for (const p of region.commonProblems) {
              const li = document.createElement("li");
              li.className = "body-prose text-ink-soft leading-[1.75]";
              const name = document.createElement("strong");
              name.className = "text-ink font-semibold";
              name.textContent = p.name;
              const desc = document.createTextNode(" — " + p.description);
              li.appendChild(name);
              li.appendChild(desc);
              list.appendChild(li);
            }
          }

          emptyState.classList.add("hidden");
          contentEl.classList.remove("hidden");
          contentEl.classList.remove("is-swapping");

          // Move focus to the title so screen readers / keyboard users know
          titleEl.focus({ preventScroll: true });

          // On mobile, smooth scroll to panel
          if (window.matchMedia("(max-width: 767px)").matches) {
            const rect = contentEl.getBoundingClientRect();
            const target =
              window.scrollY + rect.top - 80; // nav offset
            window.scrollTo({ top: target, behavior: "smooth" });
          }
        }, 160);
      }

      let activeSelectedId: string | null = null;

      const wrappedSelectRegion = selectRegion;
      function selectAndRemember(id: string) {
        activeSelectedId = id;
        wrappedSelectRegion(id);
      }

      for (const h of hotspots) {
        h.addEventListener("click", () => {
          const id = h.dataset.regionId;
          if (id) selectAndRemember(id);
        });
        h.addEventListener("keydown", (e) => {
          if (e.key === "Enter" || e.key === " ") {
            e.preventDefault();
            const id = h.dataset.regionId;
            if (id) selectAndRemember(id);
          }
        });
        // Desktop hover preview on active label
        h.addEventListener("mouseenter", () => {
          const label = h.dataset.regionLabel;
          if (label && activeLabelEl) {
            activeLabelEl.textContent = label;
            activeLabelEl.classList.add("is-active");
          }
        });
        h.addEventListener("mouseleave", () => {
          if (!activeLabelEl) return;
          if (activeSelectedId) {
            const region = byId.get(activeSelectedId);
            if (region) {
              activeLabelEl.textContent = region.label;
              activeLabelEl.classList.add("is-active");
            }
          } else {
            activeLabelEl.textContent =
              activeLabelEl.dataset.defaultText || "";
            activeLabelEl.classList.remove("is-active");
          }
        });
      }
    }
  </script>
</section>
