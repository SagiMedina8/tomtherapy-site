---
import type { Service } from "../data/services";

interface Props {
  service: Service;
  variant?: 1 | 2 | 3 | 4;
  index?: number;
}
const { service, index } = Astro.props;
const s = service;
const number = String((index ?? 0) + 1).padStart(2, "0");
---
<article
  id={s.slug}
  class="card-base service-card group flex flex-col h-full overflow-hidden fade-up"
>
  <!-- Large background number (decorative) -->
  <span
    class="service-card-number pointer-events-none select-none"
    aria-hidden="true"
  >
    {number}
  </span>

  <div class="relative z-10 flex flex-col flex-1 text-right">
    <span class="card-pill card-pill-en mb-5 self-start">{s.eyebrow}</span>
    <h3 class="card-title mb-4">{s.titleHe}</h3>
    <p class="card-body-text flex-1">{s.description}</p>

    <hr class="card-divider" />

    <a
      href={s.linkHref}
      class="inline-flex items-center gap-2 text-sm font-semibold text-ink group-hover:text-teal-deep transition-colors self-start"
    >
      <span class="border-b border-teal pb-0.5">{s.linkText}</span>
      <span aria-hidden="true">←</span>
    </a>
  </div>
</article>

<style>
  .service-card {
    border-top: 2px solid var(--teal);
  }
  .service-card-number {
    position: absolute;
    top: 12px;
    left: 24px;
    font-family: 'Fraunces', serif;
    font-weight: 200;
    font-size: 96px;
    line-height: 1;
    color: var(--teal);
    opacity: 0.08;
    z-index: 0;
  }
</style>
