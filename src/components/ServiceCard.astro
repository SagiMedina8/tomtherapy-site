---
import type { Service } from "../data/services";

interface Props {
  service: Service;
  variant: 1 | 2 | 3 | 4;
  index?: number;
}
const { service, variant, index } = Astro.props;
const s = service;
const number = String((index ?? 0) + 1).padStart(2, "0");
---
<article
  id={s.slug}
  class:list={[
    "group relative overflow-hidden bg-paper border border-hairline h-full flex flex-col fade-up",
    variant === 1 && "border-t-2 border-t-teal",
  ]}
>
  {
    variant === 4 && (
      <span
        class="pointer-events-none absolute top-4 start-6 font-display font-light text-[140px] leading-none text-ink/[0.06] select-none"
        aria-hidden="true"
      >
        {number}
      </span>
    )
  }

  <div class="relative p-8 md:p-10 flex flex-col flex-1 text-right">
    <p class="eyebrow-label text-teal-deep mb-4">{s.eyebrow}</p>
    <h3 class="section-h3 mb-4 font-bold">{s.titleHe}</h3>
    <p class="body-prose text-ink-soft mb-8 leading-[1.75] flex-1">{s.description}</p>

    <a
      href={s.linkHref}
      class="inline-flex items-center gap-2 text-sm font-semibold text-ink group-hover:text-teal-deep transition-colors self-start"
    >
      <span class="border-b border-teal pb-0.5">{s.linkText}</span>
      <span aria-hidden="true">←</span>
    </a>
  </div>
</article>
