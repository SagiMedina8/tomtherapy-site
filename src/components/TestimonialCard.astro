---
import type { Testimonial } from "../data/testimonials";
interface Props {
  testimonial: Testimonial;
}
const { testimonial: t } = Astro.props;
---
<article class="card-base flex flex-col fade-up">
  <!-- Top row: name pill + stars -->
  <div class="flex items-center justify-between gap-3 mb-5">
    <span class="card-pill">{t.name}</span>
    <div class="flex items-center gap-1" aria-label={`${t.stars} כוכבים מתוך 5`}>
      {
        Array.from({ length: t.stars }).map(() => (
          <svg width="14" height="14" viewBox="0 0 24 24" fill="#3FCBC5" aria-hidden="true">
            <path d="M12 2l2.9 6.9 7.1.6-5.4 4.7 1.7 7-6.3-3.8L5.7 21.2l1.7-7-5.4-4.7 7.1-.6L12 2z" />
          </svg>
        ))
      }
    </div>
  </div>

  <!-- quote mark (decorative) -->
  <span
    aria-hidden="true"
    class="absolute top-5 start-6 font-display text-4xl leading-none text-teal/30 select-none"
  >
    ״
  </span>

  <blockquote class="font-serif font-medium text-[20px] leading-[1.55] text-ink flex-1">
    {t.quote}
  </blockquote>

  <hr class="card-divider" />

  <footer class="card-footer-text">
    {t.role}
  </footer>
</article>
