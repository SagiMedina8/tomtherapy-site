---
import type { ProcessStep } from "../data/process-steps";
interface Props {
  step: ProcessStep;
}
const { step } = Astro.props;
---
<article class="grid grid-cols-[1fr] md:grid-cols-[auto_1fr] items-start gap-5 md:gap-12 py-12 md:py-16 border-b border-hairline fade-up">
  <div class="md:order-2 md:pt-2">
    <span
      aria-hidden="true"
      class="block font-display font-light text-teal leading-none text-[56px] sm:text-[72px] md:text-[96px]"
    >
      {step.number}
    </span>
  </div>
  <div class="md:order-1 md:pe-8">
    <h3 class="section-h3 mb-4 font-bold">{step.title}</h3>
    <p class="body-prose text-ink-soft leading-[1.8]">
      {step.description}
    </p>
  </div>
</article>
