---
import type { CollectionEntry } from "astro:content";
interface Props {
  article: CollectionEntry<"articles">;
}
const { article } = Astro.props;
const { title, tag, excerpt, readingTime } = article.data;
---
<article class="card-base group flex flex-col fade-up">
  <span class="card-pill mb-5 self-start">{tag}</span>

  <h3 class="card-title mb-4">
    <a href={`/articles/${article.slug}`} class="hover:text-teal-deep transition-colors">
      {title}
    </a>
  </h3>

  <p class="card-body-text flex-1">{excerpt}</p>

  <hr class="card-divider" />

  <div class="flex items-center justify-between gap-4">
    <a
      href={`/articles/${article.slug}`}
      class="inline-flex items-center gap-2 text-sm font-semibold text-ink group-hover:text-teal-deep transition-colors"
    >
      <span class="border-b border-teal pb-0.5">קרא</span>
      <span aria-hidden="true">←</span>
    </a>
    <span class="card-footer-text" dir="ltr">{readingTime}</span>
  </div>
</article>
