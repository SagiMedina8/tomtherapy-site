---
import { navItems } from "../data/site";
import Wordmark from "./Wordmark.astro";

interface Props {
  transparentOverHero?: boolean;
}
const { transparentOverHero = false } = Astro.props;
const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";
---

<a href="#main" class="skip-link">דלג לתוכן</a>

<header
  id="top-nav"
  data-transparent={transparentOverHero ? "true" : "false"}
  class:list={[
    "fixed inset-x-0 top-0 z-50 w-full transition-colors duration-300",
    transparentOverHero ? "is-transparent" : "is-solid",
  ]}
>
  <div class="mx-auto flex h-[68px] max-w-content items-center justify-between gap-3 px-4 sm:px-8 lg:h-[76px]">
    <!-- Right side (RTL first): logo -->
    <a
      href="/"
      class="flex items-center text-inherit"
      aria-label="עמוד הבית · SportTherapy"
    >
      <span class="hidden lg:inline-block">
        <Wordmark size="md" />
      </span>
      <span class="lg:hidden">
        <Wordmark size="sm" compact />
      </span>
    </a>

    <!-- Middle: nav items (desktop) -->
    <nav
      aria-label="ניווט ראשי"
      class="hidden lg:flex items-center gap-8 text-[15px]"
    >
      {
        navItems.map((item) => {
          const normalized = item.href.replace(/\/$/, "") || "/";
          const isActive = normalized === currentPath;
          return (
            <a
              href={item.href}
              class="nav-link nav-item-text"
              aria-current={isActive ? "page" : undefined}
            >
              {item.label}
            </a>
          );
        })
      }
    </nav>

    <!-- Left side (RTL last): CTA -->
    <div class="flex items-center gap-2 lg:gap-4">
      <a
        href="/booking"
        class="nav-cta inline-flex h-10 items-center rounded-[2px] border border-current px-4 text-sm font-semibold transition-colors"
      >
        קבע טיפול
      </a>

      <!-- Hamburger / X toggle (mobile only) -->
      <button
        type="button"
        id="nav-toggle"
        class="nav-item-text nav-toggle-btn lg:hidden relative inline-flex h-11 w-11 items-center justify-center"
        aria-label="פתח תפריט"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <span class="nav-toggle-icon" aria-hidden="true">
          <span class="nav-toggle-bar nav-toggle-bar--top"></span>
          <span class="nav-toggle-bar nav-toggle-bar--middle"></span>
          <span class="nav-toggle-bar nav-toggle-bar--bottom"></span>
        </span>
      </button>
    </div>
  </div>
</header>

<!-- Mobile: backdrop + glass side drawer -->
<div id="mobile-menu-backdrop" class="mobile-backdrop" hidden></div>

<aside
  id="mobile-menu"
  class="mobile-drawer"
  role="dialog"
  aria-modal="true"
  aria-label="תפריט ראשי"
  hidden
>
  <button
    type="button"
    id="drawer-close"
    class="drawer-close"
    aria-label="סגור תפריט"
  >
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
      <line x1="6" y1="6" x2="18" y2="18" />
      <line x1="18" y1="6" x2="6" y2="18" />
    </svg>
  </button>

  <nav aria-label="ניווט נייד" class="drawer-nav">
    {
      navItems.map((item, i) => {
        const normalized = item.href.replace(/\/$/, "") || "/";
        const isActive = normalized === currentPath;
        return (
          <a
            href={item.href}
            class:list={["drawer-link", isActive && "is-active"]}
            style={`--stagger:${i * 40}ms`}
            aria-current={isActive ? "page" : undefined}
          >
            {item.label}
          </a>
        );
      })
    }
  </nav>

  <a href="/booking" class="drawer-cta">
    קבע טיפול
  </a>
</aside>

<style>
  /* ===== Header states (unchanged) ===== */
  header.is-transparent {
    background: transparent;
    color: #ffffff;
    border-bottom: 1px solid rgba(255, 255, 255, 0.12);
  }
  header.is-transparent .nav-item-text { color: #ffffff; }
  header.is-transparent .nav-cta {
    color: #ffffff;
    border-color: rgba(255, 255, 255, 0.85);
  }
  header.is-transparent .nav-cta:hover {
    background: #ffffff;
    color: var(--ink);
  }

  header.is-solid {
    background: var(--cream);
    color: var(--ink);
    border-bottom: 1px solid var(--hairline);
  }
  header.is-solid .nav-item-text { color: var(--ink); }
  header.is-solid .nav-cta {
    color: var(--ink);
    border-color: var(--ink);
  }
  header.is-solid .nav-cta:hover {
    background: var(--ink);
    color: var(--cream);
  }

  header.is-transparent.is-scrolled {
    background: var(--cream);
    color: var(--ink);
    border-bottom-color: var(--hairline);
  }
  header.is-transparent.is-scrolled .nav-item-text { color: var(--ink); }
  header.is-transparent.is-scrolled .nav-cta {
    color: var(--ink);
    border-color: var(--ink);
  }
  header.is-transparent.is-scrolled .nav-cta:hover {
    background: var(--ink);
    color: var(--cream);
  }

  @media (max-width: 1023px) {
    .nav-cta {
      height: 36px;
      padding-inline: 0.75rem;
      font-size: 0.8125rem;
    }
  }

  /* ===== Hamburger → X transform ===== */
  .nav-toggle-icon {
    position: relative;
    width: 22px;
    height: 16px;
    display: inline-block;
  }
  .nav-toggle-bar {
    position: absolute;
    left: 0;
    right: 0;
    height: 1.5px;
    background: currentColor;
    border-radius: 2px;
    transition: transform 220ms cubic-bezier(0.22, 1, 0.36, 1),
                opacity 160ms ease,
                top 220ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  .nav-toggle-bar--top    { top: 0; }
  .nav-toggle-bar--middle { top: 7px; }
  .nav-toggle-bar--bottom { top: 14px; }

  /* When drawer is open, hamburger morphs to X (color stays ink against cream header) */
  #nav-toggle[aria-expanded="true"] {
    color: var(--ink);
  }
  #nav-toggle[aria-expanded="true"] .nav-toggle-bar--top {
    top: 7px;
    transform: rotate(45deg);
  }
  #nav-toggle[aria-expanded="true"] .nav-toggle-bar--middle {
    opacity: 0;
  }
  #nav-toggle[aria-expanded="true"] .nav-toggle-bar--bottom {
    top: 7px;
    transform: rotate(-45deg);
  }

  /* ===== Backdrop behind the drawer ===== */
  .mobile-backdrop {
    position: fixed;
    inset: 0;
    z-index: 55;
    background: rgba(15, 20, 25, 0.20);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    opacity: 0;
    pointer-events: none;
    transition: opacity 200ms ease-out;
  }
  .mobile-backdrop[hidden] {
    display: none;
  }
  .mobile-backdrop.is-open {
    opacity: 1;
    pointer-events: auto;
  }

  /* ===== Glass side drawer ===== */
  .mobile-drawer {
    position: fixed;
    top: 0;
    bottom: 0;
    left: 0;
    z-index: 60;
    width: 80vw;
    max-width: 320px;
    height: 100vh;
    height: 100svh;
    background: rgba(247, 243, 236, 0.85);
    backdrop-filter: blur(20px) saturate(180%);
    -webkit-backdrop-filter: blur(20px) saturate(180%);
    border-right: 1px solid rgba(15, 20, 25, 0.08);
    box-shadow: 8px 0 32px rgba(15, 20, 25, 0.08);
    color: var(--ink);
    display: flex;
    flex-direction: column;
    padding: 28px 28px calc(32px + env(safe-area-inset-bottom, 0px));
    transform: translateX(-100%);
    transition: transform 280ms cubic-bezier(0.32, 0.72, 0, 1);
    overflow-y: auto;
    overscroll-behavior: contain;
  }
  @media (min-width: 641px) and (max-width: 1023px) {
    .mobile-drawer {
      width: 60vw;
      max-width: 380px;
    }
  }
  .mobile-drawer[hidden] {
    display: none;
  }
  .mobile-drawer.is-open {
    transform: translateX(0);
  }
  .mobile-drawer.is-closing {
    transition: transform 240ms ease-in;
  }

  /* Fallback for browsers without backdrop-filter */
  @supports not ((backdrop-filter: blur(20px)) or (-webkit-backdrop-filter: blur(20px))) {
    .mobile-drawer {
      background: rgba(247, 243, 236, 0.97);
    }
    .mobile-backdrop {
      background: rgba(15, 20, 25, 0.35);
    }
  }

  .drawer-close {
    position: absolute;
    top: 18px;
    right: 18px;
    width: 40px;
    height: 40px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--ink);
    transition: color 180ms ease;
    -webkit-tap-highlight-color: transparent;
  }
  .drawer-close:hover,
  .drawer-close:focus-visible {
    color: var(--teal-deep);
  }

  .drawer-nav {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 18px;
    text-align: right;
    margin-top: 64px;
    margin-bottom: auto;
  }

  .drawer-link {
    font-family: 'Frank Ruhl Libre', serif;
    font-size: 26px;
    font-weight: 500;
    line-height: 1.5;
    color: var(--ink);
    transition: color 180ms ease;
    position: relative;
    padding-block: 2px;
    opacity: 0;
    transform: translateX(8px);
  }
  .mobile-drawer.is-open .drawer-link {
    animation: drawerItemIn 260ms cubic-bezier(0.22, 1, 0.36, 1) forwards;
    animation-delay: var(--stagger, 0ms);
  }
  .drawer-link::after {
    content: '';
    position: absolute;
    right: 0;
    bottom: -2px;
    height: 1px;
    width: 0;
    background: var(--teal-deep);
    transition: width 220ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  .drawer-link:hover,
  .drawer-link:focus-visible,
  .drawer-link.is-active {
    color: var(--teal-deep);
  }
  .drawer-link:hover::after,
  .drawer-link:focus-visible::after,
  .drawer-link.is-active::after {
    width: 100%;
  }

  @keyframes drawerItemIn {
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  .drawer-cta {
    display: block;
    width: 100%;
    text-align: center;
    background: var(--teal);
    color: var(--ink);
    font-family: 'Heebo', sans-serif;
    font-size: 16px;
    font-weight: 600;
    padding: 14px 24px;
    border-radius: 2px;
    margin-top: 24px;
    margin-bottom: 32px;
    transition: background 200ms ease, color 200ms ease;
  }
  .drawer-cta:hover,
  .drawer-cta:focus-visible {
    background: var(--teal-deep);
    color: #ffffff;
  }

  @media (prefers-reduced-motion: reduce) {
    .mobile-backdrop,
    .mobile-drawer,
    .drawer-link,
    .nav-toggle-bar {
      transition: none !important;
      animation: none !important;
    }
    .mobile-drawer.is-open .drawer-link {
      opacity: 1;
      transform: none;
    }
  }
</style>

<script>
  // Scroll state — for pages with transparentOverHero
  const header = document.getElementById("top-nav");
  if (header?.dataset.transparent === "true") {
    const onScroll = () => {
      if (window.scrollY > 60) {
        header.classList.add("is-scrolled");
      } else {
        header.classList.remove("is-scrolled");
      }
    };
    window.addEventListener("scroll", onScroll, { passive: true });
    onScroll();
  }

  const toggle = document.getElementById("nav-toggle");
  const closeBtn = document.getElementById("drawer-close");
  const drawer = document.getElementById("mobile-menu");
  const backdrop = document.getElementById("mobile-menu-backdrop");
  const body = document.body;

  let isOpen = false;

  function getFocusable(): HTMLElement[] {
    if (!drawer) return [];
    const sel =
      'a[href], button:not([disabled]), [tabindex]:not([tabindex="-1"])';
    return Array.from(drawer.querySelectorAll<HTMLElement>(sel)).filter(
      (el) => el.offsetParent !== null || el === document.activeElement,
    );
  }

  const openMenu = () => {
    if (!drawer || !toggle || !backdrop) return;
    isOpen = true;
    drawer.removeAttribute("hidden");
    backdrop.removeAttribute("hidden");
    // force reflow so transitions fire
    void drawer.offsetHeight;
    drawer.classList.add("is-open");
    drawer.classList.remove("is-closing");
    backdrop.classList.add("is-open");
    toggle.setAttribute("aria-expanded", "true");
    toggle.setAttribute("aria-label", "סגור תפריט");
    body.style.overflow = "hidden";
    // Focus first link
    const focusables = getFocusable();
    const firstLink = focusables.find((el) => el.tagName === "A");
    if (firstLink) firstLink.focus();
  };

  const closeMenu = () => {
    if (!drawer || !toggle || !backdrop) return;
    isOpen = false;
    drawer.classList.add("is-closing");
    drawer.classList.remove("is-open");
    backdrop.classList.remove("is-open");
    toggle.setAttribute("aria-expanded", "false");
    toggle.setAttribute("aria-label", "פתח תפריט");
    body.style.overflow = "";
    window.setTimeout(() => {
      if (!isOpen) {
        drawer.setAttribute("hidden", "");
        backdrop.setAttribute("hidden", "");
        drawer.classList.remove("is-closing");
      }
    }, 260);
    toggle.focus();
  };

  toggle?.addEventListener("click", () => {
    if (isOpen) closeMenu();
    else openMenu();
  });
  closeBtn?.addEventListener("click", closeMenu);
  backdrop?.addEventListener("click", closeMenu);

  // Close on ESC + focus trap
  document.addEventListener("keydown", (e) => {
    if (!isOpen) return;
    if (e.key === "Escape") {
      closeMenu();
      return;
    }
    if (e.key === "Tab") {
      const focusables = getFocusable();
      if (focusables.length === 0) return;
      const first = focusables[0];
      const last = focusables[focusables.length - 1];
      const active = document.activeElement as HTMLElement | null;
      if (e.shiftKey) {
        if (active === first || !drawer?.contains(active)) {
          e.preventDefault();
          last.focus();
        }
      } else {
        if (active === last) {
          e.preventDefault();
          first.focus();
        }
      }
    }
  });

  // Link click → close + delayed navigation
  drawer?.querySelectorAll<HTMLAnchorElement>("a[href]").forEach((a) => {
    a.addEventListener("click", (e) => {
      const href = a.getAttribute("href");
      if (!href) return;
      // Let cmd/ctrl-click open in new tab normally
      if (e.metaKey || e.ctrlKey || e.shiftKey || a.target === "_blank") {
        closeMenu();
        return;
      }
      e.preventDefault();
      closeMenu();
      window.setTimeout(() => {
        window.location.href = href;
      }, 100);
    });
  });

  // Close on route change (bfcache return)
  window.addEventListener("pageshow", () => {
    if (drawer && !drawer.hasAttribute("hidden")) {
      drawer.classList.remove("is-open", "is-closing");
      drawer.setAttribute("hidden", "");
      backdrop?.classList.remove("is-open");
      backdrop?.setAttribute("hidden", "");
      body.style.overflow = "";
      toggle?.setAttribute("aria-expanded", "false");
      toggle?.setAttribute("aria-label", "פתח תפריט");
      isOpen = false;
    }
  });
</script>
