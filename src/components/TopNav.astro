---
import { navItems } from "../data/site";
import Wordmark from "./Wordmark.astro";

interface Props {
  transparentOverHero?: boolean;
}
const { transparentOverHero = false } = Astro.props;
const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";
---

<a href="#main" class="skip-link">דלג לתוכן</a>

<header
  id="top-nav"
  data-transparent={transparentOverHero ? "true" : "false"}
  class:list={[
    "fixed inset-x-0 top-0 z-50 w-full transition-colors duration-300",
    transparentOverHero ? "is-transparent" : "is-solid",
  ]}
>
  <div class="mx-auto flex h-[68px] max-w-content items-center justify-between gap-3 px-4 sm:px-8 lg:h-[76px]">
    <!-- Right side (RTL first): logo -->
    <a
      href="/"
      class="flex items-center text-inherit"
      aria-label="עמוד הבית · SportTherapy"
    >
      <span class="hidden lg:inline-block">
        <Wordmark size="md" />
      </span>
      <span class="lg:hidden">
        <Wordmark size="sm" compact />
      </span>
    </a>

    <!-- Middle: nav items (desktop) -->
    <nav
      aria-label="ניווט ראשי"
      class="hidden lg:flex items-center gap-8 text-[15px]"
    >
      {
        navItems.map((item) => {
          const normalized = item.href.replace(/\/$/, "") || "/";
          const isActive = normalized === currentPath;
          return (
            <a
              href={item.href}
              class="nav-link nav-item-text"
              aria-current={isActive ? "page" : undefined}
            >
              {item.label}
            </a>
          );
        })
      }
    </nav>

    <!-- Left side (RTL last): CTA -->
    <div class="flex items-center gap-2 lg:gap-4">
      <a
        href="/booking"
        class="nav-cta inline-flex h-10 items-center rounded-[2px] border border-current px-4 text-sm font-semibold transition-colors"
      >
        קבע טיפול
      </a>

      <!-- Hamburger / X toggle (mobile only) -->
      <button
        type="button"
        id="nav-toggle"
        class="nav-item-text nav-toggle-btn lg:hidden relative inline-flex h-11 w-11 items-center justify-center"
        aria-label="פתח תפריט"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <span class="nav-toggle-icon" aria-hidden="true">
          <span class="nav-toggle-bar nav-toggle-bar--top"></span>
          <span class="nav-toggle-bar nav-toggle-bar--middle"></span>
          <span class="nav-toggle-bar nav-toggle-bar--bottom"></span>
        </span>
      </button>
    </div>
  </div>
</header>

<!-- Mobile full-screen overlay -->
<div
  id="mobile-menu"
  class="mobile-menu"
  role="dialog"
  aria-modal="true"
  aria-label="תפריט נייד"
  hidden
>
  <nav
    aria-label="ניווט נייד"
    class="mobile-menu-nav"
  >
    {
      navItems.map((item, i) => {
        const normalized = item.href.replace(/\/$/, "") || "/";
        const isActive = normalized === currentPath;
        return (
          <a
            href={item.href}
            class:list={["mobile-menu-link", isActive && "is-active"]}
            style={`--stagger:${i * 40}ms`}
            aria-current={isActive ? "page" : undefined}
          >
            {item.label}
          </a>
        );
      })
    }
  </nav>

  <a href="/booking" class="mobile-menu-cta">
    קבע טיפול
  </a>
</div>

<style>
  /* Transparent state: white content over hero */
  header.is-transparent {
    background: transparent;
    color: #ffffff;
    border-bottom: 1px solid rgba(255, 255, 255, 0.12);
  }
  header.is-transparent .nav-item-text {
    color: #ffffff;
  }
  header.is-transparent .nav-cta {
    color: #ffffff;
    border-color: rgba(255, 255, 255, 0.85);
  }
  header.is-transparent .nav-cta:hover {
    background: #ffffff;
    color: var(--ink);
  }

  /* Solid state: cream bg, ink text */
  header.is-solid {
    background: var(--cream);
    color: var(--ink);
    border-bottom: 1px solid var(--hairline);
  }
  header.is-solid .nav-item-text {
    color: var(--ink);
  }
  header.is-solid .nav-cta {
    color: var(--ink);
    border-color: var(--ink);
  }
  header.is-solid .nav-cta:hover {
    background: var(--ink);
    color: var(--cream);
  }

  /* When scrolled past hero, transparent header becomes solid */
  header.is-transparent.is-scrolled {
    background: var(--cream);
    color: var(--ink);
    border-bottom-color: var(--hairline);
  }
  header.is-transparent.is-scrolled .nav-item-text {
    color: var(--ink);
  }
  header.is-transparent.is-scrolled .nav-cta {
    color: var(--ink);
    border-color: var(--ink);
  }
  header.is-transparent.is-scrolled .nav-cta:hover {
    background: var(--ink);
    color: var(--cream);
  }

  @media (max-width: 1023px) {
    .nav-cta {
      height: 36px;
      padding-inline: 0.75rem;
      font-size: 0.8125rem;
    }
  }

  /* ===== Hamburger → X transform ===== */
  .nav-toggle-icon {
    position: relative;
    width: 22px;
    height: 16px;
    display: inline-block;
  }
  .nav-toggle-bar {
    position: absolute;
    left: 0;
    right: 0;
    height: 1.5px;
    background: currentColor;
    border-radius: 2px;
    transition: transform 220ms cubic-bezier(0.22, 1, 0.36, 1),
                opacity 160ms ease,
                top 220ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  .nav-toggle-bar--top    { top: 0; }
  .nav-toggle-bar--middle { top: 7px; }
  .nav-toggle-bar--bottom { top: 14px; }

  #nav-toggle[aria-expanded="true"] {
    color: #ffffff;
  }
  #nav-toggle[aria-expanded="true"] .nav-toggle-bar--top {
    top: 7px;
    transform: rotate(45deg);
  }
  #nav-toggle[aria-expanded="true"] .nav-toggle-bar--middle {
    opacity: 0;
  }
  #nav-toggle[aria-expanded="true"] .nav-toggle-bar--bottom {
    top: 7px;
    transform: rotate(-45deg);
  }

  /* ===== Mobile menu overlay ===== */
  .mobile-menu {
    position: fixed;
    inset: 0;
    width: 100vw;
    height: 100vh;
    height: 100svh;
    z-index: 60;
    background: var(--ink);
    color: #ffffff;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 96px 32px 0;
    opacity: 0;
    pointer-events: none;
    transition: opacity 200ms ease;
    overflow: hidden;
  }
  .mobile-menu[hidden] {
    display: none;
  }
  .mobile-menu.is-open {
    opacity: 1;
    pointer-events: auto;
  }

  .mobile-menu-nav {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 18px;
    text-align: right;
    flex: 0 0 auto;
  }

  .mobile-menu-link {
    font-family: 'Frank Ruhl Libre', serif;
    font-size: 26px;
    font-weight: 500;
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.9);
    transition: color 180ms ease;
    transform: translateX(12px);
    opacity: 0;
  }
  .mobile-menu.is-open .mobile-menu-link {
    animation: mobileMenuSlideIn 300ms cubic-bezier(0.22, 1, 0.36, 1) forwards;
    animation-delay: var(--stagger, 0ms);
  }
  .mobile-menu-link:hover,
  .mobile-menu-link.is-active {
    color: var(--teal);
  }

  @keyframes mobileMenuSlideIn {
    to {
      transform: translateX(0);
      opacity: 1;
    }
  }

  .mobile-menu-cta {
    position: absolute;
    left: 32px;
    right: 32px;
    bottom: calc(48px + env(safe-area-inset-bottom, 0px));
    width: calc(100% - 64px);
    background: var(--teal);
    color: var(--ink);
    text-align: center;
    font-family: 'Heebo', sans-serif;
    font-size: 16px;
    font-weight: 600;
    padding: 16px 32px;
    border-radius: 2px;
    transition: background 200ms ease;
    opacity: 0;
  }
  .mobile-menu.is-open .mobile-menu-cta {
    animation: mobileMenuSlideIn 300ms cubic-bezier(0.22, 1, 0.36, 1) forwards;
    animation-delay: 320ms;
  }
  .mobile-menu-cta:hover {
    background: var(--teal-deep);
    color: #ffffff;
  }

  @media (prefers-reduced-motion: reduce) {
    .mobile-menu,
    .mobile-menu-link,
    .mobile-menu-cta,
    .nav-toggle-bar {
      transition: none !important;
      animation: none !important;
      transform: none !important;
      opacity: 1 !important;
    }
  }
</style>

<script>
  // Scroll state — for pages with transparentOverHero
  const header = document.getElementById("top-nav");
  if (header?.dataset.transparent === "true") {
    const onScroll = () => {
      if (window.scrollY > 60) {
        header.classList.add("is-scrolled");
      } else {
        header.classList.remove("is-scrolled");
      }
    };
    window.addEventListener("scroll", onScroll, { passive: true });
    onScroll();
  }

  // Mobile menu
  const toggle = document.getElementById("nav-toggle");
  const menu = document.getElementById("mobile-menu");
  const body = document.body;

  let isOpen = false;

  const openMenu = () => {
    if (!menu || !toggle) return;
    isOpen = true;
    menu.removeAttribute("hidden");
    // force reflow so the transition fires
    void menu.offsetHeight;
    menu.classList.add("is-open");
    toggle.setAttribute("aria-expanded", "true");
    toggle.setAttribute("aria-label", "סגור תפריט");
    body.style.overflow = "hidden";
    const firstLink = menu.querySelector("a");
    if (firstLink instanceof HTMLElement) firstLink.focus();
  };

  const closeMenu = () => {
    if (!menu || !toggle) return;
    isOpen = false;
    menu.classList.remove("is-open");
    toggle.setAttribute("aria-expanded", "false");
    toggle.setAttribute("aria-label", "פתח תפריט");
    body.style.overflow = "";
    // Hide after fade-out transition completes
    window.setTimeout(() => {
      if (!isOpen) menu.setAttribute("hidden", "");
    }, 200);
    toggle.focus();
  };

  toggle?.addEventListener("click", () => {
    if (isOpen) closeMenu();
    else openMenu();
  });

  // Close on ESC
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && isOpen) closeMenu();
  });

  // Close when a nav link is clicked
  menu?.querySelectorAll("a").forEach((a) =>
    a.addEventListener("click", () => closeMenu()),
  );

  // Click on empty overlay area (not on a link) closes
  menu?.addEventListener("click", (e) => {
    if (e.target === menu) closeMenu();
  });

  // Close on route change (bfcache return)
  window.addEventListener("pageshow", () => {
    if (menu && !menu.hasAttribute("hidden")) {
      menu.classList.remove("is-open");
      menu.setAttribute("hidden", "");
      body.style.overflow = "";
      toggle?.setAttribute("aria-expanded", "false");
      toggle?.setAttribute("aria-label", "פתח תפריט");
      isOpen = false;
    }
  });
</script>
