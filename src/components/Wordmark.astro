---
// Text-based wordmark — uses currentColor for base, teal span for the accent.
// Parent controls text color via CSS (.is-transparent → white, .is-solid → ink).
interface Props {
  compact?: boolean;
  size?: "sm" | "md" | "lg";
  class?: string;
}
const {
  compact = false,
  size = "md",
  class: className = "",
} = Astro.props;

const sizeClasses = {
  sm: "text-base",
  md: "text-xl",
  lg: "text-2xl",
};

const wrapperSize = sizeClasses[size];
---
<span
  class={`inline-flex flex-col leading-none font-display font-light tracking-wide ${wrapperSize} ${className}`}
  style="color: currentColor;"
  aria-label="SportTherapy — Tom Kushlin"
>
  {compact ? (
    <span class="whitespace-nowrap">
      <span>Sport</span><span class="text-teal">Therapy</span>
    </span>
  ) : (
    <>
      <span class="whitespace-nowrap" style="letter-spacing:0.02em;">
        <span>Sport</span><span class="text-teal">Therapy</span>
      </span>
      <span
        class="mt-1 text-[0.55em] tracking-[0.35em] uppercase"
        style="letter-spacing:0.35em;"
      >
        Tom <span class="text-teal">Kushlin</span>
      </span>
    </>
  )}
</span>
